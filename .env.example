# Directory containing your docker-compose project folders.
# Each subdirectory should contain a docker-compose.yml or compose.yml.
COMPOSE_SCAN_DIR=~/your-compose-dir

# Port range to monitor (for the "free" count in summary).
# Only affects the summary statistic, not the grid display.
PORT_RANGE_START=1
PORT_RANGE_END=9999

# Custom port definitions file (gitignored, user-specific).
# See custom_ports.example.json for format.
CUSTOM_PORTS_FILE=./custom_ports.json
